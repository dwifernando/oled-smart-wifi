// ================== HTML ==================
String getPage() {
  String page = "<!DOCTYPE html><html><head>";
  page += "<meta name='viewport' content='width=device-width, initial-scale=1'>";
  page += "<style>";
  page += "body{font-family:sans-serif;text-align:center;background:#111;color:white;}";
  page += "button{padding:10px;margin:5px;font-size:16px;border:none;border-radius:8px;}";
  page += "input{padding:10px;width:80%;border-radius:8px;border:none;}";
  page += "</style></head><body>";

  page += "<h2>OLED Control</h2>";

  page += "<form action='/set'>";
  page += "<button name='mode' value='1'>Foto 1</button>";
  page += "<button name='mode' value='2'>Foto 2</button><br>";
  page += "<button name='mode' value='3'>Foto 3</button>";
  page += "<button name='mode' value='4'>Foto 4</button><br>";
  page += "<button name='mode' value='5'>Foto 5</button>";
  page += "<button name='mode' value='0'>Mode Teks</button><br><br>";

  page += "<input type='text' name='text' placeholder='Tulis teks...'><br><br>";
  page += "<input type='submit' value='Kirim'>";
  page += "</form>";

  page += "</body></html>";
  return page;
}

// ================== HANDLE ==================
void handleRoot() {
  server.send(200, "text/html", getPage());
}

void handleSet() {
  if (server.hasArg("mode")) {
    mode = server.arg("mode").toInt();
  }

  if (server.hasArg("text")) {
    customText = server.arg("text");

    if (customText.length() > 60) {
      customText = customText.substring(0, 60);
    }
  }

  server.send(200, "text/html", "<h3>Berhasil diubah</h3><a href='/'>Kembali</a>");
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);

  // OLED init
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  display.clearDisplay();

  // WiFi AP
  WiFi.softAP(ssid);
  dnsServer.start(53, "*", WiFi.softAPIP());

  // Web server
  server.on("/", handleRoot);
  server.on("/set", handleSet);
  server.begin();
}

// ================== LOOP ==================
void loop() {
  dnsServer.processNextRequest();
  server.handleClient();

  display.clearDisplay();

  // MODE GAMBAR
  if (mode == 1) {
    display.drawBitmap(0, 0, img1, 128, 64, WHITE);
  } else if (mode == 2) {
    display.drawBitmap(0, 0, img2, 128, 64, WHITE);
  } else if (mode == 3) {
    display.drawBitmap(0, 0, img3, 128, 64, WHITE);
  } else if (mode == 4) {
    display.drawBitmap(0, 0, img4, 128, 64, WHITE);
  } else if (mode == 5) {
    display.drawBitmap(0, 0, img5, 128, 64, WHITE);
  }

  // MODE TEKS
  else if (mode == 0) {
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(0, 0);

    display.println(customText);
  }

  display.display();
}
